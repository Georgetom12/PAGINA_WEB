# ── COPIA ESTE ARCHIVO A .env Y RELLENA LOS VALORES ──────

# Token de tu bot (obtenlo con @BotFather)
BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwXyz

# ID del canal de altcoins Tier 1-4 (número negativo, ej: -1001234567890)
# Para obtenerlo: agrega @userinfobot al canal o usa /id en el bot
CHANNEL_ID=-1001234567890

# Tu(s) ID(s) de Telegram como admin (separa con coma si son varios)
ADMIN_IDS=123456789

# Métodos de pago
PAYPAL_EMAIL=tupago@paypal.com
BINANCE_PAY_ID=TU_BINANCE_PAY_ID
BANK_INFO=Banco: Mi Banco | Cuenta: 1234-5678 | Titular: Tu Nombre

# Base de datos (Railway pone esto automático con PostgreSQL)
DATABASE_URL=sqlite:///signals_bot.db

# Panel web admin
ADMIN_PASSWORD=pon_una_clave_segura_aqui
SECRET_KEY=cadena_aleatoria_larga_aqui

# Clave API Railway / producción
PORT=8080

# Pares de cripto a monitorear (separados por coma)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Intervalo de análisis en segundos (1800 = 30 minutos recomendado para 52 coins)
SIGNAL_INTERVAL=1800
ALTCOIN_SIGNAL_INTERVAL=1800

# ── TRADINGVIEW WEBHOOK (opcional) ───────────────────────
# Pon una clave secreta aquí para activar el webhook.
# Deja vacío para desactivarlo.
# URL de tu webhook será: https://TU_DOMINIO.railway.app/webhook/tradingview?secret=TU_SECRETO
TV_WEBHOOK_SECRET=
