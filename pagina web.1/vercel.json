{
  "buildCommand": "npm install -g pnpm@9 && pnpm install --no-frozen-lockfile && pnpm --filter @workspace/psychometriks run build",
  "outputDirectory": "artifacts/psychometriks/dist/public",
  "framework": null,
  "build": {
    "env": {
      "BASE_PATH": "/"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://workspaceapi-server-production-43ce.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
