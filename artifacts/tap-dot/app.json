{
  "expo": {
    "name": "PSYCHOMETRIKS",
    "slug": "tap-dot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "psychometriks",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.psychometriks.app"
    },
    "android": {
      "package": "com.psychometriks.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#060a0f"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://psychometriks.trade/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-updates"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
